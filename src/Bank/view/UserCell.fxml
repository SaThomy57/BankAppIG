<?xml version="1.0" encoding="UTF-8" ?>
<?import javafx.scene.control.* ?>
<?import javafx.scene.layout.* ?>
<?import javafx.scene.image.* ?>

<HBox fx:id="root" spacing="15" alignment="CENTER_LEFT" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1" style="-fx-padding: 5">
    <children>
        <ImageView fitHeight="40" fitWidth="40" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="/icon/bankIcon.png" />
            </image>
        </ImageView>
        <VBox spacing="2">
            <Label fx:id="nomCompletLabel" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
            <Label fx:id="detailsLabel" style="-fx-text-fill: gray; -fx-font-size: 11px;"/>
        </VBox>
    </children>
</HBox>